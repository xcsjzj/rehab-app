  "pain_treatments": [
    {
      "name": "足底筋膜炎",
      "details": {
        "临床主诉": [
          "①足底内侧足跟痛"
        ],
        "改善/训练": [
          "①减肥"
        ]
      }
    },
    {
      "name": "跟腱炎",
      "details": {
        "临床主诉": [
          "①跟腱上方2-6cm的位置按压出现疼痛"
        ],
        "改善/训练": [
          "①体重过大的减肥"
        ]
      }
    },
    {
      "name": "踝关节",
      "details": {
        "距下关节": [
          "①足内翻 → a.胫骨前后肌"
        ]
      }
    },
    {
      "name": "踝关节韧带扭伤",
      "details": {
        "病理期": [
          "①炎症期：（4-7天）红、肿、热、痛 、瘀斑，一般只做引流处理 → 康复目标：减少细胞死亡，避免二次扭伤"
        ]
      }
    },
    {
      "name": "扁平足",
      "details": {
        "改善/训练": [
          "①肥胖者减肥"
        ]
      }
    },
    {
      "name": "足背屈（受限）",
      "details": {
        "改善/训练": [
          "①松筋膜"
        ],
        "造足背屈": [
          "弓箭步前大腿抵住会员脚掌，一手固定跖骨，一手虎口顺脚背往下推距骨位置卡住不动,用身体的力量往下斜方45度推脚掌"
        ]
      }
    },
    {
      "name": "髌骨关节痛",
      "details": {
        "临床主诉": [
          "①膝盖前方痛，上下楼梯的时候、跑步后有所增加"
        ],
        "改善/训练": [
          "①松解髂胫束、阔筋膜张肌、外侧头、大腿内收肌"
        ]
      }
